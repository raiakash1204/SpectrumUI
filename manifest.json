{
  "manifest_version": 3,
  "name": "AccessUI Auditor",
  "version": "1.0.0",
  "description": "AI-powered accessibility scanner that uses axe-core and Gemini AI to analyze web pages and provide plain-English explanations with code fixes.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "sidePanel",
    "notifications"
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "action": {
    "default_icon": {
      "48": "icons/icon48.png"
    },
    "default_title": "AccessUI Auditor"
  },
  "icons": {
    "48": "icons/icon48.png",
    "128": "icons/icon48.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["lib/axe.min.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "trigger-scan": {
      "suggested_key": {
        "default": "Alt+Shift+A",
        "mac": "Alt+Shift+A"
      },
      "description": "Trigger accessibility scan on current page"
    },
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Shift+S",
        "mac": "Alt+Shift+S"
      },
      "description": "Open AccessUI Auditor popup"
    }
  }
}
